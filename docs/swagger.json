        "handlers.UpdateDeviceRequest": {
            "type": "object",
            "properties": {
                "description": {
                    "type": "string",
                    "maxLength": 2000,
                    "example": "Under maintenance"
                },
                "ip_address": {
                    "type": "string",
                    "maxLength": 45,
                    "example": "10.0.0.2"
                },
                "location": {
                    "type": "string",
                    "maxLength": 255,
                    "example": "DC-West"
                },
                "name": {
                    "type": "string",
                    "maxLength": 255,
                    "minLength": 2,
                    "example": "Core Router 01"
                },
                "status": {
                    "type": "string",
                    "enum": [
                        "online",
                        "offline",
                        "degraded",
                        "maintenance"
                    ],
                    "example": "maintenance"
                },
                "type": {
                    "type": "string",
                    "enum": [
                        "router",
                        "tower",
                        "switch",
                        "core_node",
                        "link",
                        "service"
                    ],
                    "example": "router"
                }
            }
        },

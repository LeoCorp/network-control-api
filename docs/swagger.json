                    {
                        "type": "integer",
                        "description": "Page limit (default 10, max 100)",
                        "name": "limit",
                        "in": "query"
                    },
                    {
                        "type": "string",
                        "description": "Filter by incident status (OPEN, INVESTIGATING, RESOLVED)",
                        "name": "status",
                        "in": "query"
                    },
                    {
                        "type": "string",
                        "description": "Filter by device UUID",
                        "name": "device_id",
